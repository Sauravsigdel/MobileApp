{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "Node16",
      "moduleResolution": "node16"
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "generated", "prisma.config.ts"]
}
