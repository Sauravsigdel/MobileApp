generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model assignments {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model attendances {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model classes {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @map("__v")
  createdAt DateTime @db.Date
  isActive  Boolean
  name      String
  schoolId  String   @db.ObjectId
  updatedAt DateTime @db.Date
}

model exams {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model feerecords {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model feestructures {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model messages {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model notices {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model results {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model schools {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @map("__v")
  address   String
  createdAt DateTime @db.Date
  email     String
  isActive  Boolean
  /// Could not determine type: the field only had null or empty values in the sample set.
  logo      Json?
  name      String
  phone     String
  type      String
  updatedAt DateTime @db.Date
}

model sections {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  v              Int      @map("__v")
  classId        String   @db.ObjectId
  classTeacherId String   @db.ObjectId
  createdAt      DateTime @db.Date
  name           String
  schoolId       String   @db.ObjectId
  studentIds     String[]
  updatedAt      DateTime @db.Date
}

model students {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  v             Int      @map("__v")
  address       String
  admissionDate DateTime @db.Date
  createdAt     DateTime @db.Date
  parentName    String
  parentPhone   String
  rollNo        String
  /// Could not determine type: the field only had null or empty values in the sample set.
  sectionId     Json?
  updatedAt     DateTime @db.Date
  userId        String   @unique(map: "userId_1") @db.ObjectId
}

model subjects {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  v              Int      @map("__v")
  classId        String   @db.ObjectId
  createdAt      DateTime @db.Date
  name           String
  periodsPerWeek Int
  schoolId       String   @db.ObjectId
  teacherId      String   @db.ObjectId
  updatedAt      DateTime @db.Date
}

model submissions {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model teachers {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  v             Int      @map("__v")
  createdAt     DateTime @db.Date
  qualification String
  sectionIds    String[]
  subjectIds    String[]
  updatedAt     DateTime @db.Date
  userId        String   @unique(map: "userId_1") @db.ObjectId
}

model timetables {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model users {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @map("__v")
  /// Could not determine type: the field only had null or empty values in the sample set.
  avatar    Json?
  createdAt DateTime @db.Date
  email     String   @unique(map: "email_1")
  isActive  Boolean
  name      String
  password  String
  phone     String
  role      String
  /// Could not determine type: the field only had null or empty values in the sample set.
  schoolId  Json?
  updatedAt DateTime @db.Date
}
